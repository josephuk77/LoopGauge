{
  "name": "loopgauge",
  "version": "0.2.0",
  "description": "Find the cheapest LLM policy that still passes your project's quality gate.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josephuk77/LoopGauge.git"
  },
  "homepage": "https://github.com/josephuk77/LoopGauge#readme",
  "bugs": {
    "url": "https://github.com/josephuk77/LoopGauge/issues"
  },
  "keywords": [
    "llm",
    "cost-optimization",
    "model-routing",
    "prompt-optimization",
    "mcp",
    "ai-agents"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "loopgauge": "dist/cli.js",
    "loopgauge-mcp": "dist/mcp/server.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.ko.md",
    "CHANGELOG.md",
    "CHANGELOG.ko.md",
    "SECURITY.md",
    "SECURITY.ko.md",
    "CONTRIBUTING.md",
    "CONTRIBUTING.ko.md",
    "CODE_OF_CONDUCT.md",
    "CODE_OF_CONDUCT.ko.md",
    "docs",
    "benchmarks",
    "LICENSE",
    "LICENSE.ko.md",
    "loop.example.yaml",
    "loop.example.ko.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "tsx src/cli.ts demo",
    "dev": "tsx src/cli.ts",
    "mcp": "tsx src/mcp/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "@openai/codex-sdk": "latest",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
